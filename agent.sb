(version 1)

;; ---------------------------------------------------------------------------
;; Custom sandbox-exec profile (modeled on Agent Safehouse).
;; Project: https://github.com/eugene1g/agent-safehouse
;;
;; Assembly order mirrors Safehouse:
;;   00-base -> 10-system-runtime -> HOME ancestor metadata -> 20-network
;;   -> 30-toolchains -> 40-shared -> 50-integrations-core
;;   -> 55-integrations-optional -> 60-agents
;;
;; Workdir read/write grants are emitted by run-sandboxed.sh at launch time
;; (selected workdir + git common dir + sibling worktree snapshots). They are
;; intentionally NOT baked into this durable file so the policy adapts to
;; whatever directory you cd into before invoking yolo-sandboxed-claude (or safe-run COMMAND).
;;
;; Debug sandbox denials:
;;   /usr/bin/log stream --style compact \
;;     --predicate 'eventMessage CONTAINS "Sandbox:" AND eventMessage CONTAINS "deny("'
;; ---------------------------------------------------------------------------

;; ---------------------------------------------------------------------------
;; Base Profile
;; Core definitions, HOME_DIR replacement token, and helper macros shared by all modules.
;; Source: 00-base.sb
;; ---------------------------------------------------------------------------

(define HOME_DIR "__HOME_DIR__")

(define (home-subpath rel) (subpath (string-append HOME_DIR rel)))
(define (home-literal rel) (literal (string-append HOME_DIR rel)))
(define (home-prefix rel) (prefix (string-append HOME_DIR rel)))

(deny default)

;; ---------------------------------------------------------------------------
;; System Runtime
;; Process execution, tmp/dev access, system binaries, and baseline mach services.
;; Source: 10-system-runtime.sb
;; ---------------------------------------------------------------------------

(allow file-read*
    (subpath "/usr")                                                  ;; Core system binaries and libraries required by most spawned tools.
    (subpath "/bin")                                                  ;; POSIX userland binaries used by shell/task orchestration.
    (subpath "/sbin")                                                 ;; System utilities some build/test flows invoke.
    (subpath "/opt")                                                  ;; Homebrew and other package-manager install roots.
    (subpath "/System/Library")                                       ;; macOS runtime frameworks/resources; excludes broader /System/Volumes data paths.
    (subpath "/System/Volumes/Preboot")                               ;; Some dyld/framework lookups resolve through Preboot symlinks on modern macOS.
    (subpath "/Library/Apple")                                        ;; Apple private frameworks touched by Node/Bun/JVM/native toolchains.
    (subpath "/Library/Frameworks")                                   ;; Global framework lookup path for language runtimes and CLIs.
    (subpath "/Library/Fonts")                                        ;; Font reads used by headless renderers/PDF/image tasks.
    (subpath "/Library/Filesystems/NetFSPlugins")                     ;; Path resolution may load NetFS plugins during filesystem lookups.
    (subpath "/Library/Preferences/Logging")                          ;; macOS logging stack reads prefs during process init.
    (literal "/Library/Preferences/.GlobalPreferences.plist")         ;; Locale/time/user defaults queried by runtimes.
    (literal "/Library/Preferences/com.apple.networkd.plist")         ;; DNS/network bootstrap reads networkd config.
    (literal "/dev")                                                  ;; /dev directory listing; shells enumerate it during initialization.
)

(allow file-read-metadata
   (subpath "/System")                                                ;; stat/readdir traversal across /System during loader/framework path resolution.
   (subpath "/private/var/run")                                       ;; Metadata traversal for /private/var/run socket namespace.
)

(allow file-read*
    (literal "/private")                                              ;; Required for symlink traversal under macOS /private namespace.
    (literal "/private/var")                                          ;; Required for symlink traversal to /var-backed paths.
    (subpath "/private/var/db/timezone")                              ;; Timezone DB reads used by language date/time formatting.
    (literal "/private/var/select/sh")                                ;; /bin/sh selector used by macOS shell launch behavior.
    (literal "/private/var/select/developer_dir")                     ;; xcode-select developer dir pointer used by build CLIs.
    (literal "/var/select/developer_dir")                             ;; Compatibility alias for developer dir pointer.
    (literal "/private/var/db/xcode_select_link")                     ;; xcode-select link lookup used by toolchain discovery.
    (literal "/var/db/xcode_select_link")                             ;; Compatibility alias for xcode-select link lookup.
    (literal "/private/etc/hosts")                                    ;; Host override file consulted by resolver stack.
    (literal "/private/etc/resolv.conf")                              ;; DNS resolver configuration used by network clients.
    (literal "/private/var/run/resolv.conf")                          ;; Symlink target of /etc/resolv.conf; the literal above only matches the symlink itself.
    (literal "/private/etc/services")                                 ;; Service name-to-port mappings used by libc lookups.
    (literal "/private/etc/protocols")                                ;; Protocol metadata used by socket/libc helpers.
    (literal "/private/etc/shells")                                   ;; Valid shell list read by shell/auth tooling.
    (subpath "/private/etc/ssl")                                      ;; TLS CA bundles/certs used by HTTP and package clients.
    (literal "/private/etc/localtime")                                ;; Localtime symlink read by date/time libraries.
    (literal "/etc")                                                  ;; Compatibility symlink root for tools hardcoding /etc.
    (literal "/var")                                                  ;; Compatibility symlink root for tools hardcoding /var.
)

(allow file-read-metadata
    (literal "/home")                                                 ;; Probed during path resolution by some runtimes.
    (literal "/private/etc")                                          ;; Directory traversal for /etc path resolution.
    (subpath "/dev")                                                  ;; Metadata (stat) on /dev entries; readdir() on /dev triggers this for every node.
    (home-literal "/.config")                                         ;; XDG config root traversal needed by many tools (mise, gh, git, etc.).
    (home-literal "/.cache")                                          ;; XDG cache root traversal needed by tools probing cache locations.
    (home-literal "/.local")                                          ;; XDG data root traversal needed by tools probing ~/.local paths.
    (home-literal "/.local/share")                                    ;; XDG data share dir traversal needed by tools probing data locations.
)

(allow file-read*
    (home-prefix "/Library/Preferences/.GlobalPreferences")           ;; User-level locale/defaults plist variants read by many frameworks.
    (home-prefix "/Library/Preferences/com.apple.GlobalPreferences")  ;; Apple namespaced variant of user GlobalPreferences.
    (home-subpath "/Library/Preferences/ByHost")                      ;; Per-host preferences read by security CLI and system frameworks.
    (home-literal "/.CFUserTextEncoding")                             ;; User text encoding prefs; read by many processes for correct string handling.
    (home-literal "/.config")                                         ;; XDG config root directory listing for tool discovery.
    (home-literal "/.cache")                                          ;; XDG cache root directory listing for tool discovery.
    (home-literal "/.local/bin")                                      ;; PATH probing may readdir ~/.local/bin before spawning user-installed helpers.
)

(allow process-exec)                                                  ;; Required to execute toolchain binaries, shells, and repo tools.
(allow process-fork)                                                  ;; Required for normal child-process trees in CLI agents.
(allow sysctl-read)                                                   ;; Runtime/process introspection used by many CLIs at startup.
(allow process-info* (target same-sandbox))                           ;; Allow process introspection within the same sandbox.
(allow signal (target same-sandbox))                                  ;; Allow signalling child processes for cancellation/termination.
(allow mach-priv-task-port (target same-sandbox))                     ;; Required by some runtimes for same-sandbox process controls.
(allow pseudo-tty)                                                    ;; Required for interactive terminal sessions and PTY allocation.

(allow file-read* file-write*
    (subpath "/tmp")                                                  ;; Primary temp dir for transient files and IPC sockets.
    (subpath "/private/tmp")                                          ;; macOS backing path for /tmp.
    (subpath "/var/folders")                                          ;; macOS per-user temp/cache roots used by many CLIs.
    (subpath "/private/var/folders")                                  ;; macOS backing path for /var/folders.
)

;; Defense-in-depth: keep launchd-managed per-user listener sockets opt-in by specific integration profiles.
(deny file-read* file-write*
    (regex #"^/private/tmp/com\.apple\.launchd\.[^/]+/Listeners$")
    (regex #"^/tmp/com\.apple\.launchd\.[^/]+/Listeners$")
)

(allow file-read* file-write*
    (subpath "/dev/fd")
    (literal "/dev/stdout")
    (literal "/dev/stderr")
    (literal "/dev/null")
    (literal "/dev/tty")
    (literal "/dev/ptmx")
    (literal "/dev/dtracehelper")
    (regex #"^/dev/tty")
    (regex #"^/dev/ttys")
    (regex #"^/dev/pty")
)

(allow file-read*
    (literal "/dev/zero")
    (literal "/dev/autofs_nowait")
    (literal "/dev/dtracehelper")
    (literal "/dev/urandom")
    (literal "/dev/random")
)

(allow file-ioctl
    (literal "/dev/dtracehelper")
    (literal "/dev/tty")
    (literal "/dev/ptmx")
    (regex #"^/dev/tty")
    (regex #"^/dev/ttys")
    (regex #"^/dev/pty")
)

(allow mach-lookup
    (global-name "com.apple.system.notification_center")
    (global-name "com.apple.system.opendirectoryd.libinfo")
    (global-name "com.apple.logd")
    (global-name "com.apple.FSEvents")
    (global-name "com.apple.SystemConfiguration.configd")
    (global-name "com.apple.SystemConfiguration.DNSConfiguration")
    (global-name "com.apple.trustd.agent")
    (global-name "com.apple.diagnosticd")
    (global-name "com.apple.analyticsd")
    (global-name "com.apple.dnssd.service")
    (global-name "com.apple.CoreServices.coreservicesd")
    (global-name "com.apple.DiskArbitration.diskarbitrationd")
    (global-name "com.apple.analyticsd.messagetracer")
    (global-name "com.apple.system.logger")
    (global-name "com.apple.coreservices.launchservicesd")
)

(allow system-socket)

(allow ipc-posix-shm-read-data
    (ipc-posix-name "apple.shm.notification_center")
)

;; ---------------------------------------------------------------------------
;; Generated HOME ancestor metadata access for home-scoped runtime/toolchain discovery.
;; (Mirrors Safehouse's policy_render_emit_home_ancestor_metadata_access.)
;; ---------------------------------------------------------------------------
(allow file-read-metadata
    (literal "/")
    (literal "/Users")
    (literal "__HOME_DIR__")
)

;; ---------------------------------------------------------------------------
;; Network
;; Network policy; intentionally fully open for reliable agent operation
;; (package installs, API calls, web fetches, local dev servers).
;; Source: 20-network.sb
;; ---------------------------------------------------------------------------

(allow network*)

;; Strict alternatives (commented):
;; (allow network-outbound)
;; (allow network-bind (local ip "localhost:*"))
;; (allow network-inbound (local ip "localhost:*"))

;; ---------------------------------------------------------------------------
;; Toolchain: Apple Toolchain Core
;; Curated Apple Command Line Tools binaries and support data, needed for
;; native gem extension compilation (cc/clang/ld/ar/...).
;; Source: 30-toolchains/apple-toolchain-core.sb
;; ---------------------------------------------------------------------------

(allow file-read*
    (literal "/Library")
    (literal "/Library/Developer")
    (literal "/Library/Developer/CommandLineTools")
    (literal "/Library/Developer/CommandLineTools/usr")
    (literal "/Library/Developer/CommandLineTools/usr/bin")
    (literal "/Library/Developer/CommandLineTools/usr/include")
    (literal "/Library/Developer/CommandLineTools/usr/lib")
    (literal "/Library/Developer/CommandLineTools/usr/libexec")
    (literal "/Library/Developer/CommandLineTools/usr/libexec/git-core")
    (literal "/Library/Developer/CommandLineTools/usr/share")
    (literal "/Library/Developer/CommandLineTools/SDKs")

    (literal "/Library/Developer/CommandLineTools/usr/bin/git")
    (literal "/Library/Developer/CommandLineTools/usr/bin/make")
    (literal "/Library/Developer/CommandLineTools/usr/bin/gnumake")
    (literal "/Library/Developer/CommandLineTools/usr/bin/c++")
    (literal "/Library/Developer/CommandLineTools/usr/bin/cc")
    (literal "/Library/Developer/CommandLineTools/usr/bin/clang")
    (literal "/Library/Developer/CommandLineTools/usr/bin/gcc")
    (literal "/Library/Developer/CommandLineTools/usr/bin/g++")
    (literal "/Library/Developer/CommandLineTools/usr/bin/cpp")
    (literal "/Library/Developer/CommandLineTools/usr/bin/ar")
    (literal "/Library/Developer/CommandLineTools/usr/bin/ranlib")
    (literal "/Library/Developer/CommandLineTools/usr/bin/as")
    (literal "/Library/Developer/CommandLineTools/usr/bin/ld")
    (literal "/Library/Developer/CommandLineTools/usr/bin/ld-classic")
    (literal "/Library/Developer/CommandLineTools/usr/bin/libtool")
    (literal "/Library/Developer/CommandLineTools/usr/bin/lipo")
    (literal "/Library/Developer/CommandLineTools/usr/bin/install_name_tool")
    (literal "/Library/Developer/CommandLineTools/usr/bin/strip")

    (literal "/Library/Developer/CommandLineTools/usr/bin/m4")
    (literal "/Library/Developer/CommandLineTools/usr/bin/bison")
    (literal "/Library/Developer/CommandLineTools/usr/bin/yacc")
    (literal "/Library/Developer/CommandLineTools/usr/bin/flex")

    (literal "/Library/Developer/CommandLineTools/usr/bin/clang-format")
    (literal "/Library/Developer/CommandLineTools/usr/bin/clangd")
    (literal "/Library/Developer/CommandLineTools/usr/bin/nm")
    (literal "/Library/Developer/CommandLineTools/usr/bin/otool")
    (literal "/Library/Developer/CommandLineTools/usr/bin/strings")
    (literal "/Library/Developer/CommandLineTools/usr/bin/size")

    (subpath "/Library/Developer/CommandLineTools/usr/libexec/git-core")
    (subpath "/Library/Developer/CommandLineTools/usr/include")
    (subpath "/Library/Developer/CommandLineTools/usr/lib")
    (subpath "/Library/Developer/CommandLineTools/usr/share")
    (subpath "/Library/Developer/CommandLineTools/SDKs")
)

;; ---------------------------------------------------------------------------
;; Toolchain: Ruby
;; RVM, gem, bundler caches. Covers `bundle install`, `rspec`, native gem
;; extension builds, irb/pry history.
;; Source: 30-toolchains/ruby.sb
;; ---------------------------------------------------------------------------

;; System Ruby and Bundler enumerate the default gemspec catalog under
;; /Library/Ruby/Gems/... even for read-only commands like `bundle --version`.
(allow file-read*
    (literal "/Library")
    (literal "/Library/Ruby")
    (subpath "/Library/Ruby/Gems")
)

(allow file-read* file-write*
    (home-subpath "/.rbenv")
    (home-subpath "/.rvm")                 ;; RVM root: rubies, gemsets, scripts, hooks.
    (home-subpath "/.rubies")
    (home-subpath "/.bundle")              ;; ~/.bundle/config etc.
    (home-subpath "/.gem")
    (home-subpath "/.cache/bundler")
    (home-subpath "/.cache/rubygems")
    (home-subpath "/.cache/rubocop_cache")
    (home-subpath "/Library/Caches/bundle")
    (home-literal "/.gemrc")
    (home-literal "/.irbrc")
    (home-literal "/.irb_history")
    (home-literal "/.pryrc")
    (home-literal "/.pry_history")
)

;; ---------------------------------------------------------------------------
;; Toolchain: Runtime Managers
;; asdf is installed on this machine and may be probed even when running
;; RVM-managed Ruby (shims under ~/.asdf/shims appear in PATH lookups).
;; Source: 30-toolchains/runtime-managers.sb (asdf subset)
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/.asdf")
    (home-subpath "/.config/asdf")
    (home-subpath "/.local/share/asdf")
    (home-subpath "/.local/state/asdf")
    (home-subpath "/.cache/asdf")
    (home-subpath "/Library/Caches/asdf")
    (home-literal "/.asdfrc")
    (home-literal "/.tool-versions")
)

;; ---------------------------------------------------------------------------
;; Shared Agent Context
;; ~/.skills, ~/.agents, ~/AGENTS.md (RW); cross-agent claude/skills dirs and
;; ~/CLAUDE.md (RO).
;; Source: 40-shared/agent-common.sb
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/.skills")
    (home-subpath "/.agents")
    (home-literal "/AGENTS.md")
)

(allow file-read*
    (home-subpath "/.claude/agents")
    (home-subpath "/.claude/skills")
    (home-literal "/CLAUDE.md")
)

;; ---------------------------------------------------------------------------
;; Integration: Git
;; User gitconfig variants, XDG git config dir, SSH host alias resolution.
;; Source: 50-integrations-core/git.sb
;; ---------------------------------------------------------------------------

(allow file-read*
    (home-prefix "/.gitconfig")
    (home-prefix "/.gitignore")
    (home-subpath "/.config/git")
    (home-literal "/.gitattributes")
    (home-literal "/.ssh")
    (home-literal "/.ssh/config")
    (home-literal "/.ssh/known_hosts")
)

;; ---------------------------------------------------------------------------
;; Integration: SCM CLIs
;; GitHub/GitLab CLI state. Useful for `gh pr view` etc.
;; Source: 50-integrations-core/scm-clis.sb
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/.config/gh")
    (home-subpath "/.cache/gh")
    (home-subpath "/.local/share/gh")
    (home-subpath "/.local/state/gh")
    (home-subpath "/.config/glab-cli")
    (home-subpath "/.cache/glab-cli")
    (home-subpath "/.local/share/glab-cli")
    (home-subpath "/.local/state/glab-cli")
)

;; ---------------------------------------------------------------------------
;; Integration: Launch Services
;; Lets `open <file>` resolve a handler. Required by some agent flows.
;; Source: 50-integrations-core/launch-services.sb
;; ---------------------------------------------------------------------------

(allow mach-lookup
    (global-name "com.apple.lsd.mapdb")
    (global-name "com.apple.lsd.modifydb")
    (global-name "com.apple.coreservices.quarantine-resolver")
)

(allow file-issue-extension
    (extension-class "com.apple.app-sandbox.read")
    (extension-class "com.apple.app-sandbox.read-write")
)

(allow lsopen)

;; ---------------------------------------------------------------------------
;; Integration: Container Runtime Default Deny
;; Block Docker/OrbStack/Podman sockets at both file and unix-socket layers.
;; OrbStack + /opt/podman are installed on this machine; keep them firewalled.
;; Source: 50-integrations-core/container-runtime-default-deny.sb
;; ---------------------------------------------------------------------------

(deny file-read* file-write*
    (literal "/var/run/docker.sock")
    (literal "/private/var/run/docker.sock")
    (literal "/var/run/podman/podman.sock")
    (literal "/private/var/run/podman/podman.sock")
    (home-literal "/.docker/run/docker.sock")
    (home-literal "/.rd/docker.sock")
    (home-literal "/.orbstack/run/docker.sock")
    (regex (string-append "^" HOME_DIR "/\\.colima/docker\\.sock$"))
    (regex (string-append "^" HOME_DIR "/\\.colima/[^/]+/docker\\.sock$"))
)

;; Docker/Podman clients connect() over AF_UNIX, which sandbox-exec classifies as
;; network-outbound; deny that path too.
(deny network-outbound
    (remote unix-socket (path-literal "/var/run/docker.sock"))
    (remote unix-socket (path-literal "/private/var/run/docker.sock"))
    (remote unix-socket (path-literal "/var/run/podman/podman.sock"))
    (remote unix-socket (path-literal "/private/var/run/podman/podman.sock"))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.docker/run/docker\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.rd/docker\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.orbstack/run/docker\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.colima/docker\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.colima/[^/]+/docker\\.sock$")))
)

;; ---------------------------------------------------------------------------
;; Integration: SSH Agent Default Deny
;; Block agent-backed SSH auth (launchd Listeners socket + ~/.ssh/agent).
;; Source: 50-integrations-core/ssh-agent-default-deny.sb
;; ---------------------------------------------------------------------------

(deny network-outbound
    (remote unix-socket (path-regex #"^/private/tmp/com\.apple\.launchd\.[^/]+/Listeners$"))
    (remote unix-socket (path-regex #"^/tmp/com\.apple\.launchd\.[^/]+/Listeners$"))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.ssh/agent(/.*)?$")))
)

;; ---------------------------------------------------------------------------
;; Integration: Git Worktree Common Dir (template — rules emitted at launch)
;; Source: 50-integrations-core/worktree-common-dir.sb
;; ---------------------------------------------------------------------------
;; If the selected workdir is a linked git worktree whose shared common dir
;; lives outside the workdir, run-sandboxed.sh emits an explicit RW subpath
;; rule for that common dir at launch time.

;; ---------------------------------------------------------------------------
;; Integration: Worktrees (template — rules emitted at launch)
;; Source: 50-integrations-core/worktrees.sb
;; ---------------------------------------------------------------------------
;; run-sandboxed.sh snapshots `git worktree list` at launch and emits
;; read-only subpath grants for sibling worktrees. New worktrees created
;; after launch are NOT visible to the running sandbox.

;; ---------------------------------------------------------------------------
;; Integration: Keychain
;; Required by claude-code / codex / cursor-agent for credential storage.
;; Source: 55-integrations-optional/keychain.sb
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/Library/Keychains")
    (home-literal "/Library/Preferences/com.apple.security.plist")
)

(allow file-read*
    (literal "/Library/Preferences/com.apple.security.plist")
    (literal "/Library/Keychains/System.keychain")
    (subpath "/private/var/db/mds")
)

(allow file-read-metadata
    (home-literal "/Library")
    (home-literal "/Library/Keychains")
    (literal "/Library")
    (literal "/Library/Keychains")
)

(allow mach-lookup
    (global-name "com.apple.SecurityServer")
    (global-name "com.apple.security.agent")
    (global-name "com.apple.securityd.xpc")
    (global-name "com.apple.security.authhost")
    (global-name "com.apple.secd")
    (global-name "com.apple.trustd")
)

(allow ipc-posix-shm-read-data ipc-posix-shm-write-create ipc-posix-shm-write-data
    (ipc-posix-name "com.apple.AppleDatabaseChanged")
)

;; ---------------------------------------------------------------------------
;; Integration: Headless Chrome (Capybara/Selenium feature specs)
;; Allow webdrivers/selenium to locate and exec Chrome + chromedriver.
;; ---------------------------------------------------------------------------

(allow file-read*
    (subpath "/Applications/Google Chrome.app")                       ;; Chrome binary + frameworks; needed by webdrivers detection and Chrome's own loader.
    (home-subpath "/.webdrivers")                                     ;; Cached chromedriver binary managed by the webdrivers gem.
    (home-subpath "/Library/Preferences")                             ;; Chrome reads many per-user prefs plists (Accessibility, CoreGraphics, Dock, Keystone, etc.). Broad grant to avoid whack-a-mole.
    (home-subpath "/Library/Application Support/Google")              ;; Google subtree under Application Support (RLZ, Keystone, Updater state).
    (home-subpath "/Library/Google")                                  ;; Per-user Google software-update state (Keystone Actives).
    (home-subpath "/Applications")                                    ;; Chrome enumerates per-user Applications dir (includes Chrome Apps.localized).
    (subpath "/Library/Google")                                       ;; System-wide GoogleSoftwareUpdate bundle + brand plist.
    (subpath "/Library/Application Support/Google")                   ;; System-wide GoogleUpdater state probed by Chrome on launch.
    (subpath "/Library/Managed Preferences")                          ;; MDM-managed prefs probed by Chrome's policy loader (no-op when unmanaged).
    (subpath "/Library/Application Support/Apple/Spotlight")          ;; Spotlight metadata probed by Chrome's file dialogs/integration.
    (subpath "/Library/DriverExtensions")                             ;; Driver-extension metadata probed during graphics/IO init.
    (subpath "/System/Applications")                                  ;; Chrome enumerates system apps (Preview etc.) for default-app discovery.
    (subpath "/Applications")                                         ;; Chrome enumerates installed apps for protocol-handler discovery.
    (home-subpath "/Library/Mobile Documents")                        ;; iCloud Drive metadata probed by Chrome file dialogs.
    (home-subpath "/Library/Keyboard Layouts")                        ;; Per-user keyboard layouts probed by Chrome's input init (Chrome 148+).
    (home-subpath "/Library/Input Methods")                           ;; Per-user IME bundles probed by Chrome's input init (Chrome 148+).
    (home-subpath "/Library/Spelling")                                ;; Per-user spell-check dictionaries probed by Chrome (Chrome 148+).
    (literal "/Library/Preferences/com.apple.HIToolbox.plist")        ;; HIToolbox global prefs probed by Chrome's input subsystem (Chrome 148+).
    (literal "/private/var/db/.AppleSetupDone")                       ;; Boot-state marker probed by macOS frameworks.
    (subpath "/private/var/db/eligibilityd")                          ;; Apple feature-eligibility data probed during framework init.
    (literal "/private/etc")                                          ;; Directory data for /etc; metadata-only grant elsewhere isn't enough for Chrome's resolver path.
)

(allow file-read* file-write*
    (home-subpath "/Library/Application Support/Google/Chrome")       ;; Chrome user profile dir; Crashpad + state writes happen here on every launch.
)

(allow file-link
    (subpath "/private/var/folders")                                  ;; Chrome creates per-launch code-sign clones via hardlinks under macOS user temp dirs.
    (subpath "/tmp")                                                  ;; Same mechanism via the /tmp alias on some systems.
)

(allow mach-lookup
    (global-name "com.apple.bsd.dirhelper")                           ;; _dirhelper_userdir lookup used early in process startup.
    (global-name "com.apple.distributed_notifications@Uv3")           ;; macOS distributed notification center used by Chrome.
    (global-name "com.apple.dock.server")                             ;; Dock server lookup probed by Chrome on launch (no-op when headless).
    (global-name "com.apple.dock.fullscreen")                         ;; Dock fullscreen helper probed by Chrome.
    (global-name "com.apple.pasteboard.1")                            ;; Pasteboard service queried by Chrome at startup.
    (global-name "com.apple.system.opendirectoryd.api")               ;; Directory service API used by libsystem_info for user/uid lookups.
    (global-name "com.apple.system.opendirectoryd.membership")        ;; Group membership lookups via libsystem_info.
    (global-name "com.apple.tccd")                                    ;; Per-user TCC daemon probed by Chrome.
    (global-name "com.apple.tccd.system")                             ;; System TCC daemon probed by Chrome (camera/mic/etc. prompts, no-op headless).
    (global-name "com.apple.windowserver.active")                     ;; WindowServer probed by headless Chrome; lookup is allowed to fail.
    (global-name "com.apple.window_proxies")                          ;; Window-proxy server probed by Chrome's window subsystem.
    (global-name "com.apple.windowmanager.server")                    ;; Stage Manager / window manager server probed by Chrome.
    (global-name "com.apple.CARenderServer")                          ;; Core Animation render server lookup from Chrome's compositor init.
    (global-name "com.apple.GSSCred")                                 ;; Kerberos cred store; Chrome's network stack probes this even when unused.
    (global-name "com.apple.ctkd.token-client")                       ;; CryptoTokenKit daemon probed by Chrome's smartcard support.
    (global-name "com.apple.CodeSigningHelper")                       ;; Code-signing XPC helper invoked by Chrome's per-launch self-check.
    (global-name "com.apple.CoreAuthentication.agent")                ;; LocalAuthentication agent probed by Chrome (no-op headless).
    (global-name "com.apple.CoreAuthentication.agent.libxpc")         ;; LocalAuthentication agent (libxpc transport).
    (global-name "com.apple.CoreLocation.agent")                      ;; CoreLocation agent probed by Chrome's geolocation.
    (global-name "com.apple.locationd.desktop.registration")          ;; locationd registration endpoint.
    (global-name "com.apple.PowerManagement.control")                 ;; Power-management control probed by Chrome.
    (global-name "com.apple.SafariLaunchAgent")                       ;; Probed by Chrome's default-browser detection.
    (global-name "com.apple.backupd.sandbox.xpc")                     ;; Time Machine sandbox XPC probed during file-system init.
    (global-name "com.apple.bird")                                    ;; iCloud bird daemon probed by Chrome.
    (global-name "com.apple.bird.token")                              ;; iCloud bird token endpoint.
    (global-name "com.apple.coreservices.appleevents")                ;; AppleEvents server probed by Chrome.
    (global-name "com.apple.hiservices-xpcservice")                   ;; HIServices XPC probed by Chrome's window subsystem.
    (global-name "com.apple.iohideventsystem")                        ;; HID event system probed by Chrome input init.
    (global-name "com.apple.logd.events")                             ;; logd event endpoint probed by Chrome's logging.
    (global-name "com.apple.metadata.mds")                            ;; Spotlight metadata daemon probed by Chrome's file dialogs.
    (global-name "com.apple.pbs.fetch_services")                      ;; Pasteboard server fetch endpoint.
    (global-name "com.apple.spotlight.IndexAgent")                    ;; Spotlight index agent probed by Chrome.
    (global-name "com.apple.usernoted.client")                        ;; User notification daemon probed by Chrome.
    (global-name "com.apple.touchbarserver.mig")                      ;; TouchBar server probed by Chrome's input init (Chrome 148+); no-op on non-TouchBar Macs.
    (global-name "com.google.GoogleUpdater.update.system")            ;; Chrome's GoogleUpdater XPC; no-op when updater isn't installed.
    (global-name-prefix "com.google.Chrome.")                         ;; Chrome subprocesses look up MachPortRendezvousServer.<pid> + apps.<hash> registered by sibling/parent processes.
    (global-name-prefix "org.chromium.crashpad.")                     ;; Crashpad subprocesses look up the child_port_handshake registered by the parent.
)

(allow mach-register
    (local-name-prefix "")                                             ;; Per-pid local mach names registered by Apple frameworks (axserver, coredrag, tsm.portname).
    (global-name-prefix "com.google.Chrome.")                          ;; Chrome's MachPortRendezvousServer.<pid> and apps.<hash> global registrations.
    (global-name-prefix "org.chromium.crashpad."))                     ;; Crashpad child-port handshake registrations.

(allow iokit-open
    (iokit-user-client-class "RootDomainUserClient")                  ;; Chrome's power-management probing on startup.
    (iokit-user-client-class "AGXDeviceUserClient")                   ;; GPU device client probed by Chrome's compositor.
    (iokit-user-client-class "AppleUSBHostDeviceUserClient")          ;; USB device enumeration probed by Chrome.
    (iokit-user-client-class "IOHIDParamUserClient")                  ;; HID input params probed by Chrome.
    (iokit-user-client-class "IOSurfaceRootUserClient")               ;; IOSurface backing for Chrome's compositor.
)

(allow user-preference-read
    (preference-domain "com.apple.hitoolbox")                         ;; HIToolbox (input method) prefs probed by Chrome.
)

;; Chrome 148+ note — `forbidden-sandbox-reinit` is NOT a grantable operation.
;; Chromium's renderer/GPU/utility helpers try to apply their own internal
;; seatbelt sandbox on top of the outer sandbox-exec profile. The kernel
;; unconditionally blocks this and logs `deny(1) forbidden-sandbox-reinit`;
;; the helper then exits, surfacing in chromedriver as
;; `invalid session id: session deleted because browser closed the connection`.
;; There is no `(allow ...)` for it — `sandbox-exec` rejects the token with
;; `unbound variable: forbidden-sandbox-reinit`. The standard fix is to pass
;; `--no-sandbox` to Chrome via the project's Capybara/Selenium config; the
;; outer sandbox-exec profile already provides confinement, so disabling
;; Chrome's redundant inner sandbox is safe.

;; ---------------------------------------------------------------------------
;; Agent: Claude Code
;; ~/.local/bin/claude, ~/.claude, ~/.claude.json, MCP config, managed policy.
;; Source: 60-agents/claude-code.sb
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-prefix "/.local/bin/claude")
    (home-subpath "/.cache/claude")
    (home-subpath "/.claude")
    (home-prefix "/.claude.json")
    (home-literal "/.claude.lock")
    (home-subpath "/.config/claude")
    (home-subpath "/.local/state/claude")
    (home-subpath "/.local/share/claude")
    (home-literal "/.mcp.json")
)

(allow file-read*
    (home-prefix "/.claude.json.")
    (home-literal "/Library/Application Support/Claude/claude_desktop_config.json")
    (subpath "/Library/Application Support/ClaudeCode/.claude")
    (literal "/Library/Application Support/ClaudeCode/managed-settings.json")
    (literal "/Library/Application Support/ClaudeCode/managed-mcp.json")
    (literal "/Library/Application Support/ClaudeCode/CLAUDE.md")
)

;; VS Code external-editor handoff (Ctrl+G) metadata-only allowances.
(allow file-read-metadata
    (literal "/Applications")
    (subpath "/Applications/Visual Studio Code.app")
    (subpath "/Applications/Visual Studio Code - Insiders.app")
)

;; ---------------------------------------------------------------------------
;; Agent: Codex
;; Source: 60-agents/codex.sb
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-prefix "/.local/bin/codex")
    (home-subpath "/.codex")
    (home-subpath "/.cache/codex")
)

(allow file-read*
    (home-literal "/Library/Preferences/com.openai.codex.plist")
    (literal "/Library/Preferences/com.openai.codex.plist")
    (literal "/Library/Managed Preferences/com.openai.codex.plist")
    (subpath "/etc/codex")
)

;; ---------------------------------------------------------------------------
;; Agent: cursor-agent
;; Source: 60-agents/cursor-agent.sb
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-prefix "/.local/bin/agent")
    (home-prefix "/.local/bin/cursor-agent")
    (home-prefix "/.local/bin/cursor")
    (home-subpath "/.local/share/cursor-agent")
    (home-subpath "/.cursor")
    (home-subpath "/.config/cursor")
    (home-subpath "/.cache/cursor-compile-cache")
    (home-subpath "/Library/Caches/cursor-compile-cache")
)

(allow file-read*
    (home-subpath "/Library/Application Support/Cursor")
    (literal "/Applications")
    (literal "/usr/local/bin/cursor")
    (literal "/opt/homebrew/bin/cursor")
    (subpath "/Applications/Cursor.app")
)

;; ---------------------------------------------------------------------------
;; End of durable profile. Workdir read/write and worktree grants are appended
;; by run-sandboxed.sh at launch time.
;; ---------------------------------------------------------------------------
